                {
                  href: "/directory",
                  icon: Compass,
                  title: "Browse Directory",
                  desc: "All 47 clubs with filters & map",
                },
                {
                  href: "/resources",
                  icon: BookOpen,
                  title: "Resource Library",
                  desc: "Guides, templates, handbooks",
                },
                {
                  href: "/start-a-club",
                  icon: Rocket,
                  title: "Start a Club",
                  desc: "Club creation wizard",
                },
                {
                  href: "/hub/mentors",
                  icon: GraduationCap,
                  title: "Find a Mentor",
                  desc: "Connect with alumni & professionals",
                },
                {
                  href: "/events",
                  icon: Calendar,
                  title: "Events Calendar",
                  desc: "All upcoming events",
                },
              ].map((item) => {
                const Icon = item.icon;
                return (
                  <Link
                    key={item.href}
                    href={item.href}
                    className="bg-white border border-neutral-200 p-3.5 flex items-center gap-3 hover:border-primary-200 hover:shadow-sm transition-all group"
                  >
                    <div className="w-8 h-8 bg-primary-50 text-primary-600 flex items-center justify-center shrink-0">
                      <Icon size={15} />
                    </div>
                    <div className="flex-1 min-w-0">
                      <p className="font-bold text-xs text-primary-700 group-hover:text-primary-600 transition-colors">
                        {item.title}
                      </p>
                      <p className="text-[11px] text-neutral-400 mt-0.5">
                        {item.desc}
                      </p>
                    </div>
                    <ArrowRight
                      size={12}
                      className="text-neutral-300 group-hover:text-primary-400 shrink-0 transition-colors"
                    />
                  </Link>
                );
              })}
            </div>
          </div>
        </div>

        {/* Announcements */}
        {announcements.length > 0 && (
          <section>
            <h2 className="text-xl font-heading font-bold text-primary-800 mb-3">
