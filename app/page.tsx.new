                >
                  <div className="text-center bg-primary-800 text-white px-3 py-2 min-w-[52px] shrink-0">
                    <div className="text-[9px] uppercase font-semibold tracking-wider">
                      {new Date(event.date).toLocaleDateString("en-US", {
                        month: "short",
                      })}
                    </div>
                    <div className="text-lg font-bold font-heading leading-tight">
                      {new Date(event.date).getDate()}
                    </div>
                  </div>
                  <div className="flex-1 min-w-0">
                    <p className="font-semibold text-primary-700 text-sm group-hover:text-primary-600 transition-colors">
                      {event.title}
                    </p>
                    <p className="text-xs text-neutral-500 mt-0.5">
                      {event.chapterName} &middot; {event.startTime}&ndash;{event.endTime}
                    </p>
                  </div>
                  <div className="hidden sm:flex items-center gap-1 text-[11px] text-neutral-400 shrink-0">
                    <MapPin size={10} /> {event.location}
                  </div>
                </Link>
              ))}
            </div>
          </div>

          {/* Get Involved sidebar */}
          <div>
            <h2 className="text-xl font-heading font-bold text-primary-800 mb-4">
              Get Involved
