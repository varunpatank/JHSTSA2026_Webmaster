                    <p className="font-bold text-sm text-primary-800">
                      {ann.title}
                    </p>
                    <p className="text-xs text-neutral-500 mt-1 leading-relaxed line-clamp-2">
                      {ann.content}
                    </p>
                  </div>
                </div>
              ))}
            </div>
          </section>
        )}

        {/* CTA Banner */}
        <section className="relative overflow-hidden bg-primary-900 border border-primary-700 p-8 md:p-10 text-center text-white">
