              >
                Browse Clubs <ArrowRight size={14} />
              </Link>
              <Link
                href="/start-a-club"
                className="inline-flex items-center gap-2 px-6 py-2.5 border-2 border-white/55 text-white font-semibold text-sm hover:border-white hover:bg-white/10 transition-colors btn-magnetic"
