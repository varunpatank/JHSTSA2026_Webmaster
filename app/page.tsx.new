                href={`/directory/${club.id}`}
                className="bg-white border border-neutral-200 p-4 hover:border-primary-300 hover:-translate-y-0.5 hover:shadow-sm transition-all group"
              >
                <div className="flex items-center gap-2 mb-2.5">
                  <span className="text-lg">{CLUB_ICONS[club.name] || "⭐"}</span>
                  <span className="text-[10px] font-semibold uppercase tracking-wider text-primary-500 border border-primary-200 bg-primary-50 px-2 py-0.5">
                    {club.category}
                  </span>
                  <span
                    className={`ml-auto text-[10px] px-1.5 py-0.5 font-medium ${
                      club.membershipStatus === "Open Enrollment"
                        ? "bg-green-50 text-green-700 border border-green-200"
                        : "bg-amber-50 text-amber-700 border border-amber-200"
                    }`}
                  >
                    {club.membershipStatus === "Open Enrollment" ? "Open" : "Apply"}
                  </span>
                </div>
                <h3 className="font-bold text-primary-800 text-sm group-hover:text-primary-600 transition-colors">
                  {club.name}
                </h3>
                <p className="text-xs text-neutral-500 mt-1 line-clamp-2 leading-relaxed">
                  {club.description}
                </p>
                <div className="flex items-center justify-between mt-3 pt-2.5 border-t border-neutral-100 text-[10px] text-neutral-400">
                  <span className="flex items-center gap-1">
                    <Users size={9} /> {club.memberCount} members
                  </span>
                  <span className="flex items-center gap-1">
                    <MapPin size={9} /> {club.meetingLocation.room}
                  </span>
                </div>
              </Link>
            ))}
          </div>
        </section>

        {/* Events + Get Involved sidebar */}
        <div className="grid lg:grid-cols-3 gap-5">
          {/* Events list */}
          <div className="lg:col-span-2">
            <div className="flex items-end justify-between mb-4">
              <h2 className="text-xl font-heading font-bold text-primary-800">
                Upcoming Events
              </h2>
              <Link
