              <div className="relative w-full max-w-[420px]">
                {/* Main photo card */}
                <div className="relative h-[300px] overflow-hidden border border-white/10 shadow-[0_24px_64px_rgba(0,0,0,0.55)] animate-float">
                  <Image
                    src="https://images.unsplash.com/photo-1511578314322-379afb476865?auto=format&fit=crop&w=900&q=80"
