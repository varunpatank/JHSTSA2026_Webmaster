            fill
            className="object-cover opacity-15"
            loading="lazy"
          />
          <div className="relative z-10">
            <p className="eyebrow text-secondary-300 mb-3">Your community is waiting</p>
            <h2 className="text-2xl md:text-3xl font-heading font-bold">
              Ready to find your club?
            </h2>
            <p className="mt-3 text-white/70 text-sm max-w-lg mx-auto leading-relaxed">
