                iconColor: "text-accent-500",
                iconBg: "bg-red-50",
                hoverBorder: "hover:border-red-200",
              },
              {
                icon: Users,
                title: "Find Your Community",
                desc: "47 active clubs spanning arts, science, culture, leadership, service, sports, and more. Your people are here.",
                iconColor: "text-primary-600",
                iconBg: "bg-primary-50",
                hoverBorder: "hover:border-primary-200",
              },
              {
                icon: BookOpen,
                title: "Resources & Tools",
                desc: "Guides, templates, handbooks, and club management tools to help you run — or join — a thriving club.",
                iconColor: "text-green-600",
                iconBg: "bg-green-50",
                hoverBorder: "hover:border-green-200",
              },
            ].map((item) => {
              const Icon = item.icon;
              return (
                <div
                  key={item.title}
                  className={`bg-white border border-neutral-200 ${item.hoverBorder} p-5 hover:shadow-sm transition-all`}
                >
                  <div
                    className={`w-10 h-10 ${item.iconBg} ${item.iconColor} flex items-center justify-center mb-3`}
                  >
                    <Icon size={18} />
                  </div>
                  <h3 className="font-bold text-sm text-primary-800 mb-1.5">
                    {item.title}
                  </h3>
                  <p className="text-xs text-neutral-500 leading-relaxed">
                    {item.desc}
                  </p>
                </div>
              );
            })}
          </div>
        </div>
      </section>

      {/* ─── MAIN CONTENT GRID ─────────────────────────────────── */}
      <div className="max-w-6xl mx-auto px-4 sm:px-6 py-10 space-y-10">

        {/* Featured Clubs */}
        <section>
          <div className="flex items-end justify-between mb-4">
            <div>
              <p className="eyebrow">Find Your People</p>
              <h2 className="mt-0.5 text-xl md:text-2xl font-heading font-bold text-primary-800">
                Featured Clubs
              </h2>
            </div>
            <Link
              href="/directory"
              className="inline-flex items-center gap-1 text-xs font-semibold text-primary-600 hover:text-primary-800 transition-colors hover:underline underline-offset-2"
            >
              View all {chapters.length} clubs <ArrowRight size={12} />
            </Link>
          </div>

          <div className="grid sm:grid-cols-2 lg:grid-cols-3 gap-3">
            {featuredClubs.map((club) => (
              <Link
