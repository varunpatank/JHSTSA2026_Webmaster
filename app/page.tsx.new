                    className="object-cover"
                  />
                  <div className="absolute inset-0 bg-gradient-to-t from-primary-900/55 via-transparent to-transparent" />
                  {/* Live badge */}
                  <div className="absolute top-3 left-3 inline-flex items-center gap-1.5 bg-primary-900/80 backdrop-blur-sm border border-white/15 px-2.5 py-1">
                    <span className="w-1.5 h-1.5 rounded-full bg-secondary-400 animate-pulse inline-block" />
                    <span className="text-[10px] font-semibold text-white uppercase tracking-wider">
                      Live Community
                    </span>
                  </div>
                </div>

                {/* Upcoming event overlay */}
                {nextEvent && (
